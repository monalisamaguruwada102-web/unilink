{
  "expo": {
    "name": "UniLink",
    "slug": "unilink",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polyconnect.unilink"
    },
    "android": {
      "package": "com.polyconnect.unilink",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "8f3b9c83-358c-439e-8bf7-c60a20e403df"
      }
    },
    "plugins": [
      "expo-location",
      "expo-file-system"
    ]
  }
}
